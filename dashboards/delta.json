{
  "annotations": { "list": [] },
  "description": "Default observability dashboard for delta_server. Panels read directly from the /metrics Prometheus endpoint. Compatible with Grafana 9.x and 10.x.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "iteration": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "delta_uptime_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Requests / sec (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(rate(delta_http_requests_total{instance=~\"$instance\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "id": 4,
      "title": "Cache hit rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green",  "value": 0.85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [
        { "expr": "avg(delta_cache_hit_rate{instance=~\"$instance\"})", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Active connections",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(delta_connections_active{instance=~\"$instance\"})", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "HTTP traffic & latency",
      "type": "row"
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "HTTP responses by status class (rate, 1m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 25, "stacking": { "mode": "normal" } } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "mean"] } },
      "targets": [
        { "expr": "sum by (class) (rate(delta_http_responses_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{class}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "5xx error ratio (rolling 5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 0.005 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(delta_http_responses_total{instance=~\"$instance\",class=\"5xx\"}[5m])) / clamp_min(sum(rate(delta_http_requests_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        },
        {
          "expr": "sum(rate(delta_http_responses_total{instance=~\"$instance\",class=\"4xx\"}[5m])) / clamp_min(sum(rate(delta_http_requests_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "4xx ratio",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Latency p50/p95/p99 (ms, by route)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, path) (rate(delta_http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])))", "legendFormat": "p50 {{path}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le, path) (rate(delta_http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])))", "legendFormat": "p95 {{path}}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le, path) (rate(delta_http_request_duration_ms_bucket{instance=~\"$instance\"}[5m])))", "legendFormat": "p99 {{path}}", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Rate-limited requests / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(delta_http_rate_limited_total{instance=~\"$instance\"}[5m]))", "legendFormat": "rate-limited", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "HTTP worker thread pool",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "delta_http_threads{instance=~\"$instance\"}",     "legendFormat": "max threads", "refId": "A" },
        { "expr": "delta_connections_active{instance=~\"$instance\"}", "legendFormat": "active conns", "refId": "B" },
        { "expr": "delta_connections_total{instance=~\"$instance\"}",  "legendFormat": "total conns",  "refId": "C" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 12,
      "panels": [],
      "title": "Storage, cache & vectors",
      "type": "row"
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Documents (gauge)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "delta_documents_total{instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "SSTable count",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "delta_storage_sstables{instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "Cache memory (bytes)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "delta_cache_memory_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 16,
      "title": "Cache hits vs misses (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(delta_cache_hits_total{instance=~\"$instance\"}[5m]))",   "legendFormat": "hits/s",   "refId": "A" },
        { "expr": "sum(rate(delta_cache_misses_total{instance=~\"$instance\"}[5m]))", "legendFormat": "misses/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "id": 17,
      "title": "Vectors (count) & HNSW indexes",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "delta_vector_vectors_total{instance=~\"$instance\"}", "legendFormat": "vectors",       "refId": "A" },
        { "expr": "delta_vector_indexes{instance=~\"$instance\"}",      "legendFormat": "HNSW indexes",  "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 18,
      "panels": [],
      "title": "WebSocket & DeltaQL traffic",
      "type": "row"
    },
    {
      "type": "timeseries",
      "id": 19,
      "title": "WebSocket frames (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(delta_ws_frames_sent_total{instance=~\"$instance\"}[5m]))", "legendFormat": "sent/s", "refId": "A" },
        { "expr": "sum(rate(delta_ws_frames_recv_total{instance=~\"$instance\"}[5m]))", "legendFormat": "recv/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "DeltaQL bytes (rate, 5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "sum(rate(delta_deltaql_bytes_sent_total{instance=~\"$instance\"}[5m]))", "legendFormat": "sent",  "refId": "A" },
        { "expr": "sum(rate(delta_deltaql_bytes_recv_total{instance=~\"$instance\"}[5m]))", "legendFormat": "recv",  "refId": "B" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["delta", "deltaql", "database"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Prometheus",
        "options": [],
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(delta_uptime_seconds, instance)",
        "query": { "query": "label_values(delta_uptime_seconds, instance)", "refId": "StandardVariableQuery" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "label": "Instance",
        "options": [],
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "",
  "title": "Delta — Overview",
  "uid": "delta-overview",
  "version": 1,
  "weekStart": ""
}
